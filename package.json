{
  "name": "cypress-webtables-automation",
  "version": "1.0.0",
  "description": "Cypress automation test for demoqa.com Web Tables using Page Object Model (POM) and data-driven testing",
  "author": "Senior QA Engineer",
  "license": "MIT",
  "scripts": {
    "cy:open": "cypress open",
    "cy:run": "cypress run --browser chrome",
    "cy:run:positive": "cypress run --browser chrome --spec 'cypress/e2e/webTables/positive.cy.js'",
    "cy:run:negative": "cypress run --browser chrome --spec 'cypress/e2e/webTables/negative.cy.js'",
    "cy:run:all": "cypress run --browser chrome --spec 'cypress/e2e/webTables/*.cy.js'"
  },
  "devDependencies": {
    "@4tw/cypress-drag-drop": "^2.3.1",
    "cypress": "^13.17.0",
    "cypress-real-events": "^1.15.0",
    "dotenv": "^16.4.5"
  }
}
